<% layout("/layouts/boilerplate") %>
<div class="row mt-3">
    <div class="col-8 offset-2">
        <br>
    <h3 style="text-align: center;">Edit your Listings</h3>
    <form method="post" action="/listings/<%= listing._id %>?_method=PUT">
        <div class="mb-3">
            <label for="title" class="form-label">Title</label>
            <input value="<%= listing.title %>" name="listing[title]" class="form-control">
        </div>
        <div class="mb-3">
            <label for="description" class="form-label">Description</label>
            <textarea class="form-control" name="listing[description]"><%= listing.description %></textarea>
        </div>
        <div class="mb-3">
            <label for="image" class="form-label">Image URL</label>
            <input value="<%= listing.image %>" name="listing[image]" type="text" class="form-control">
        </div>
        <!--Price and row tooks in single line-->
        <div class="row">
        <div class="mb-3 col-md-4">
            <label for="price" class="form-label">Price</label>
            <input value="<%= listing.price %>" name="listing[price]" type="number" class="form-control">
        </div>
        <div class="mb-3 col-md-8">
            <label for="country" class="form-label">Country</label>
            <input value="<%= listing.country %>" name="listing[country]" class="form-control">
        </div>
        </div>

        <div class="mb-3">
            <label for="location" class="form-label">Location</label>
            <input value="<%= listing.location %>" name="listing[location]" class="form-control">
        </div>
        <button type="submit" class="btn btn-dark edit-btn edit-btn mt-3">Edit</button>
    </form>
    </div>
</div>
